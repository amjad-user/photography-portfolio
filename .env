# Copy this file to .env and fill in your values

# Server port (default: 3000)
PORT=3000

# JWT secret — change this to a long random string before going live!
JWT_SECRET=change-this-to-a-very-long-random-string-in-production

# Default admin credentials (used only if no admin exists in the database)
# After first run, use the admin dashboard to change these
ADMIN_EMAIL=admin@portfolio.com
ADMIN_PASSWORD=admin123
