PORT=3000

# Supabase — find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Required by the server (used for all admin/server-side DB operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# JWT secret — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=replace-with-a-long-random-string

# Default admin credentials (used by: node setup-admin.js)
ADMIN_EMAIL=admin@portfolio.com
ADMIN_PASSWORD=admin123
